<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Spin The Wheel</title>
<style>
  body {
    background: #1a1a2e;
    color: white;
    font-family: Arial, sans-serif;
    text-align: center;
    padding-top: 40px;
  }
  #wheel {
    width: 300px;
    height: 300px;
    border: 8px solid white;
    border-radius: 50%;
    margin: 20px auto;
    position: relative;
    transition: transform 4s ease-out;
  }
  .slice {
    position: absolute;
    width: 50%;
    height: 50%;
    transform-origin: 100% 100%;
    clip-path: polygon(0 0, 100% 0, 100% 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: #000;
  }
  #pointer {
    width: 0;
    height: 0;
    border-left: 15px solid transparent;
    border-right: 15px solid transparent;
    border-bottom: 25px solid red;
    margin: 0 auto;
  }
  button {
    padding: 15px 40px;
    font-size: 18px;
    background: #ffcc00;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-weight: bold;
    margin-top: 20px;
  }
  #result {
    margin-top: 20px;
    font-size: 22px;
    color: #ffcc00;
  }
</style>
</head>
<body>

<h1>🎡 Spin The Wheel 🎡</h1>
<div id="pointer"></div>
<div id="wheel"></div>
<button onclick="spin()">SPIN</button>
<div id="result"></div>

<script>
const options = ["$10", "Try Again", "$50", "Bonus", "$20", "Lose"];
const colors = ["#ffcc00", "#ff0066", "#00ccff", "#66ff66", "#ff66ff", "#ff9900"];
const wheel = document.getElementById("wheel");
let deg = 0;

options.forEach((txt, i) => {
  const slice = document.createElement("div");
  slice.className = "slice";
  slice.style.background = colors[i];
  slice.style.transform = `rotate(${i * 60}deg)`;
  slice.innerText = txt;
  wheel.appendChild(slice);
});

function spin() {
  const random = Math.floor(Math.random() * 360) + 1800;
  deg += random;
  wheel.style.transform = `rotate(${deg}deg)`;
  
  setTimeout(() => {
    const winner = options[Math.floor(Math.random() * options.length)];
    document.getElementById("result").innerText = "You got: " + winner;
  }, 4000);
}
</script>

</body>
</html>
